# ─────────────────────────────────────────────────────────────────────────────
# .env.example — template of environment variables read by the app.
#
# Fill each var in a local .env.local (gitignored) for development, and in the
# Vercel dashboard (Production + Preview scopes) for deployed environments.
# Empty values are placeholders — set them before running `npm run dev`
# or deploying. Never commit real values to this file.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase (public URL + anon key + service_role) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URL (used in Stripe redirects, email links, OAuth callbacks) ───────
# Prod: https://www.mirvo.ai — Preview: matching Vercel preview URL
NEXT_PUBLIC_APP_URL=

# ─── Stripe (secret + webhook + 6 price IDs + 3 launch coupons) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_POWER_MONTHLY=
STRIPE_PRICE_POWER_YEARLY=
STRIPE_COUPON_LAUNCH_STARTER=
STRIPE_COUPON_LAUNCH_PRO=
STRIPE_COUPON_LAUNCH_POWER=

# ─── Instantly (email provider — real send + webhook HMAC secret) ───────────
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=

# ⚠️ DEV / LOCAL ONLY — must NEVER be `true` in Production or Preview.
# When `true`, the app silently swaps Instantly for a MockEmailProvider:
# no real emails are sent, DB rows still transition to `sent`, users see
# success but nothing goes out. This flag is the historical root cause of
# silent-send outages. Leave commented / unset in Vercel.
# MOCK_EMAIL_PROVIDER=true

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=
# Verified sender identity — must match a domain configured in Resend.
# Prod: `Mirvo <hello@mirvo.ai>`
FROM_ADDRESS=

# ─── Anthropic (Claude — bot + draft generation + morning brief) ────────────
ANTHROPIC_API_KEY=

# ─── PostHog (product analytics + error tracking) ───────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
# EU cloud (mirvo project is EU-region — never point to us.i.posthog.com).
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Cloudflare Turnstile (signup CAPTCHA) ──────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Cron auth (Vercel Cron bearer token) ───────────────────────────────────
# Must match the `Authorization: Bearer …` header configured on each Vercel Cron.
CRON_SECRET=

# ─── Admin observability (destination for cost alerts, health alerts) ───────
# Prod: admin@mirvo.ai (Cloudflare alias → forward to human inbox).
# Absent = alert skipped + logged in cron_runs.summary_data.alert_skipped_reason
# (no personal fallback — see D9 sprint).
ADMIN_NOTIFICATION_EMAIL=

# ─── Sentra admin gate (comma-separated emails allowed to reach /admin) ─────
# Absent = no one can reach /admin (fail-closed).
SENTRA_ADMIN_EMAILS=

# ─── OAuth token encryption (AES-256-GCM master passphrase) ─────────────────
# Minimum 32 chars. Generate with: openssl rand -hex 32
# Rotating this key invalidates every stored OAuth token — do it deliberately.
SENTRA_ENCRYPTION_KEY=

# ─── Upstash Redis (rate-limit backing store) ───────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Node env (typically set by the platform — Vercel injects `production`) ─
# NODE_ENV=development
